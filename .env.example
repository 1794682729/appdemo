# 生产环境变量（复制为 .env 并填写真实值）
# 不要提交 .env 到 Git

# 会话密钥 — 用 openssl rand -hex 32 生成
SESSION_SECRET=change-me-in-production

# 允许的前端域名（CORS）
ALLOWED_ORIGIN=https://your.domain.com

# MySQL 数据库连接
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=liushui

# 端口
PORT=3001

# 环境
NODE_ENV=production

# AI 服务（DeepSeek API）
DEEPSEEK_API_KEY=sk-your-api-key-here
