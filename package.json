{
  "name": "liushui-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @liushui/api --filter @liushui/web dev",
    "dev:api": "pnpm --filter @liushui/api dev",
    "dev:web": "pnpm --filter @liushui/web dev",
    "build": "pnpm --filter @liushui/shared build && pnpm --filter @liushui/api build && pnpm --filter @liushui/web build",
    "build:shared": "pnpm --filter @liushui/shared build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
